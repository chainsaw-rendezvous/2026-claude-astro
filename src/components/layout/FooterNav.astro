    <div class="grid md:grid-cols-2 gap-8">
      <!-- Left: Appalachian Arts -->
      <div class="flex flex-col gap-4">
        <img src="/assets/appArts-logo.png" alt="Appalachian Arts Studio" class="h-16 w-auto object-contain" />
        <h3 class="text-lg font-semibold text-gray-800">Appalachian Arts Studio</h3>
