---
import ExternalLink from '../ui/ExternalLink.astro';
import sponsorData from '../../data/sponsors.json';

const levels = [1, 2, 3, 4];
---

<section class="py-12 bg-white">
  <div class="section-container">
    <h2 class="text-3xl font-bold text-center text-gray-900 mb-10">Thanks to our sponsors</h2>

    {levels.map((level) => (
      <div class={`flex flex-wrap justify-center items-center gap-6 mb-8 sponsor-level-${level}`}>
        {sponsorData.filter((s) => s.level === level).map((s) => (
          <ExternalLink href={s.href} class="block p-3 hover:opacity-80 transition-opacity">
            <img src={s.img} alt={s.alt} class="object-contain" />
          </ExternalLink>
        ))}
      </div>
    ))}
  </div>
</section>
