---
import { event } from '../../config/event';

const slides = [
  // {
  //   image: '/assets/2019/hero-slides/2018-quick-carve.jpg',
  //   alt: 'Quick Carve Demonstration at the 2018 Rendezvous',
  //   headline: `Get ready for the ${event.year} Rendezvous`,
  //   subheadline: event.displayDates,
  //   detail: `Held at ${event.location.name.toUpperCase()} · ${event.location.address}`,
  // },
  {
    // image: '/assets/2019/hero-slides/2018-quick-carve.jpg',
    image: '/assets/2026/hero-slides/IMG_1289.jpeg',
    alt: 'Quick Carve Demonstration at the 2018 Rendezvous',
    headline: `The 25th annual Chainsaw Rendezvous`,
    subheadline: event.displayDates,
    detail: `Held at ${event.location.name.toUpperCase()} · ${event.location.address}`,
  },
];
---

<section class="relative w-full overflow-hidden" style="height: 70vh; min-height: 400px;" id="tc-hero">
  {slides.map((slide, i) => (
    <div
      class:list={['hero-slide absolute inset-0', { active: i === 0 }]}
      data-slide={i}
    >
      <img
        src={slide.image}
        alt={slide.alt}
        class="absolute inset-0 w-full h-full object-cover"
      />
      <!-- Dark overlay -->
      <div class="absolute inset-0 bg-black/50"></div>
      <!-- Content -->
      <div class="relative z-10 flex flex-col items-center justify-center h-full text-center text-white px-4">
        <h1 class="text-3xl md:text-5xl font-bold drop-shadow-lg mb-3">{slide.headline}</h1>
        {slide.subheadline && (
          <h2 class="text-2xl md:text-4xl font-bold drop-shadow-lg mb-4">{slide.subheadline}</h2>
        )}
        {slide.detail && (
          <p class="text-base md:text-lg drop-shadow">{slide.detail}</p>
        )}
      </div>
    </div>
  ))}

  {slides.length > 1 && (
    <>
      <button
        id="slide-prev"
        class="absolute left-4 top-1/2 -translate-y-1/2 z-20 text-white bg-black/30 hover:bg-black/50 rounded-full p-2 transition-colors"
        aria-label="Previous slide"
      >
        <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7" />
        </svg>
      </button>
      <button
        id="slide-next"
        class="absolute right-4 top-1/2 -translate-y-1/2 z-20 text-white bg-black/30 hover:bg-black/50 rounded-full p-2 transition-colors"
        aria-label="Next slide"
      >
        <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7" />
        </svg>
      </button>
    </>
  )}
</section>

{slides.length > 1 && (
  <script>
    const slides = document.querySelectorAll('.hero-slide');
    let current = 0;
    const show = (i) => {
      slides.forEach((s, idx) => s.classList.toggle('active', idx === i));
      current = i;
    };
    document.getElementById('slide-prev')?.addEventListener('click', () =>
      show((current - 1 + slides.length) % slides.length)
    );
    document.getElementById('slide-next')?.addEventListener('click', () =>
      show((current + 1) % slides.length)
    );
    setInterval(() => show((current + 1) % slides.length), 5000);
  </script>
)}
